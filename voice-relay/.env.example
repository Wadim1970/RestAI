# ============================================================
# voice-relay — сервис-ретранслятор голосового ИИ (OpenAI Realtime).
# Живёт ОТДЕЛЬНО от waiter-api — тот стоит на Cloud.ru (Россия), туда
# OpenAI не пропустит соединение. Этот сервис должен стоять на сервере
# в Казахстане (там же, где сейчас n8n) — исходящее соединение к OpenAI
# тогда идёт с казахстанского IP, а не российского.
# ============================================================

# Порт, на котором слушает сервис
PORT=8081

# Домен фронта гостя (через запятую, если их несколько)
CORS_ORIGIN=https://guest.restai.pro

# Какой провайдер обслуживает голосовые сессии: openai | grok
# Переключение — целиком через этот флаг + перезапуск pm2, без деления
# по сессиям. Grok совместим по протоколу с OpenAI Realtime API
# (https://docs.x.ai/developers/model-capabilities/audio/voice-agent),
# ключ и кредиты — в console.x.ai.
VOICE_PROVIDER=openai

# --- OpenAI Realtime ---
OPENAI_API_KEY=
# Модель легко сменить на GPT-Live-1, когда у неё появится доступ по API.
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_REALTIME_VOICE=alloy

# --- xAI Grok Voice Agent (используется только при VOICE_PROVIDER=grok) ---
GROK_API_KEY=
GROK_VOICE_MODEL=grok-voice-latest
# Встроенные голоса на выбор: eve (по умолчанию), ara, rex, sal, leo
GROK_VOICE=eve

# --- Supabase (тот же проект, что у фронта — анонимный ключ, НЕ секрет) ---
SUPABASE_URL=https://supabase.insis.pro
SUPABASE_ANON_KEY=

# Публичный, закэшированный на Vercel Edge эндпоинт меню RestAI —
# используется вместо отдельного похода в Supabase за карточками блюд.
MENU_API_BASE_URL=https://guest.restai.pro

# Максимум одновременных голосовых разговоров. Держим с запасом ниже
# теоретического потолка по TPM для gpt-realtime на Tier 1 OpenAI (см.
# Settings -> Limits в кабинете OpenAI; на Tier 1 это ~20-40 разговоров
# при 40 000 TPM, точная цифра зависит от того, насколько непрерывно
# говорят гости). Поднимите, когда перейдёте на более высокий тир.
MAX_CONCURRENT_SESSIONS=15
